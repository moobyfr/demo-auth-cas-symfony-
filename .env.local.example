# Copy this file to .env.local and adjust values for your environment.
# .env.local is ignored by git.

# CAS server base URL (no trailing slash recommended)
CAS_URL=https://cas.example.edu/cas

# CAS protocol endpoints
CAS_LOGIN_PATH=/login
CAS_VALIDATE_PATH=/serviceValidate
CAS_LOGOUT_PATH=/logout

# Optional when running built-in PHP server on another host/port
# DEFAULT_URI=http://127.0.0.1:8000
